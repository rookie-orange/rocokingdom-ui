{
  "name": "rocokingdom-ui",
  "version": "0.0.1-beta.0",
  "description": "Rocokingdom UI components.",
  "keywords": [
    "components",
    "design-system",
    "react",
    "rocokingdom",
    "rocokingdom-ui",
    "ui"
  ],
  "homepage": "https://github.com/rookie-orange/rocokingdom-ui#readme",
  "bugs": {
    "url": "https://github.com/rookie-orange/rocokingdom-ui/issues"
  },
  "license": "MIT",
  "author": "Charles Lee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rookie-orange/rocokingdom-ui.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./font.css": "./dist/font.css",
    "./fonts/roco-kingdom-rune.ttf": "./dist/fonts/roco-kingdom-rune.ttf",
    "./fonts/roco-kingdom-sans.ttf": "./dist/fonts/roco-kingdom-sans.ttf",
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "catalog:",
    "@radix-ui/react-avatar": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-navigation-menu": "catalog:",
    "@radix-ui/react-popover": "catalog:",
    "@radix-ui/react-progress": "catalog:",
    "@radix-ui/react-radio-group": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-slider": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-toast": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "@rocokingdom-ui/icons": "workspace:*",
    "clsx": "catalog:",
    "cmdk": "catalog:",
    "date-fns": "catalog:",
    "embla-carousel-react": "catalog:",
    "lucide-react": "catalog:",
    "react-day-picker": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
