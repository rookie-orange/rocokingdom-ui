{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "lib": ["ES2023", "DOM"],
    "jsx": "react-jsx",
    "types": ["vite-plus/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "paths": {
      "@rocokingdom-ui/tokens": ["../../packages/tokens/src/index.ts"],
      "rocokingdom-ui/style.css": ["../../packages/ui/src/style.css.ts"],
      "rocokingdom-ui": ["../../packages/ui/src/index.ts"]
    },
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
